{
  "name": "eeis-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "build:android": "npx eas-cli build --platform android --profile preview --non-interactive",
    "build:ios": "npx eas-cli build --platform ios --profile preview --non-interactive",
    "build:all": "npx eas-cli build --platform all --profile preview --non-interactive",
    "release:android": "npx eas-cli build --platform android --profile production --non-interactive",
    "release:ios": "npx eas-cli build --platform ios --profile production --non-interactive",
    "release:all": "npx eas-cli build --platform all --profile production --non-interactive",
    "submit:android": "npx eas-cli submit --platform android",
    "submit:ios": "npx eas-cli submit --platform ios",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "^55.0.13",
    "expo-file-system": "^55.0.20",
    "expo-font": "~14.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
